# .env.local.example — ll-corporate local development
#
# Copy to .env.local before running pnpm dev:
#   cp .env.local.example .env.local
#
# Then fill in AUTH_KEYCLOAK_SECRET (see step below).
#
# AUTH_KEYCLOAK_SECRET is the only value that cannot be pre-filled here.
# It is generated by Keycloak when you create the ll-corporate client.
#
# ── LOCAL URL NOTE ────────────────────────────────────────────────────────────
# next.config.ts sets basePath="/corporate". All routes are under that prefix.
# The app entry point is:
#   http://localhost:3000/corporate          (pnpm dev direct)
#   http://corporate.localhost/corporate     (via Traefik)
#
# Hitting http://corporate.localhost (no /corporate) returns a 404 from Next.js.
#
# ── MANUAL BOOTSTRAP STEP (one time after first LL-task-tracker bootstrap) ───
#   1. Open http://auth.localhost
#   2. Sign in as admin / your KEYCLOAK_ADMIN_PASSWORD from LL-task-tracker/.env.local
#   3. Select realm: localhost
#   4. Clients → Create client
#        Client ID:            ll-corporate
#        Client authentication: ON
#   5. Valid redirect URIs:   http://corporate.localhost/*
#      Web origins:           http://corporate.localhost
#   6. Credentials tab → copy Client secret → paste below as AUTH_KEYCLOAK_SECRET
#
# FUTURE AUTOMATION: this client registration should be added to the
# demo-data-loader seed data or a committed Keycloak realm export under
# configs/keycloak/ in LL-task-tracker. Until then it is a one-time manual step.

# ── Backend API ───────────────────────────────────────────────────────────────
LL_TASK_TRACKER_API_BASE_URL=http://matters.localhost/api

# ── App base URLs ─────────────────────────────────────────────────────────────
# All URLs must include the /corporate basePath prefix.
LL_CORPORATE_APP_BASE_URL=http://corporate.localhost/corporate
LL_CORPORATE_POST_LOGIN_REDIRECT_URL=http://corporate.localhost/corporate/app
LL_CORPORATE_LOGOUT_REDIRECT_URL=http://corporate.localhost/corporate

# ── Auth.js ───────────────────────────────────────────────────────────────────
# AUTH_URL must include the /corporate basePath prefix.
# auth.ts hardcodes authBasePath="/corporate/api/auth"; AUTH_URL must match
# so NextAuth constructs the correct callback URL for Keycloak.
AUTH_SECRET=replace-with-any-random-32-character-string
AUTH_TRUST_HOST=true
AUTH_URL=http://corporate.localhost/corporate/api/auth

# ── Keycloak OIDC ─────────────────────────────────────────────────────────────
# Issuer must be reachable from both the server side (Node process on host)
# and the browser. Both resolve auth.localhost via /etc/hosts → 127.0.0.1 → Traefik → keycloak:8080.
# Realm name is "localhost" — set by MONGO_DEMO_DATA_LOADER_DATABASE in LL-task-tracker/.env.local.
AUTH_KEYCLOAK_ISSUER=http://auth.localhost/realms/localhost
AUTH_KEYCLOAK_ID=ll-corporate
AUTH_KEYCLOAK_SECRET=         # paste client secret here after Keycloak setup
